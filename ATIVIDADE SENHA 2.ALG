Algoritmo "Atividade senha 2"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 19/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
  u, s: caracter
  t: inteiro
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
  t <- 0
  enquanto t < 3  faca
  Escreval (" Digite seu usuario: ")
  leia(u)
  Escreval (" Digite sua senha: ")
  leia(s)

  se( u = "MarcosWillyam") e (s = "Marcos777") entao
  escreval("Login Realizado com sucesso")
  t <- 3
  senao
  escreval ("senha incorreta, tente Novamente!")
  t <- t + 1
  fimse
  fimenquanto
  se (u <> "MarcosWillyam") ou (s <> "Marcos777") entao
  Escreval("Login Bloqueado! Voce tentou 3 vezes.")
  fimse

Fimalgoritmo